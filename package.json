{
  "name": "alaseel-pod",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env.local -- drizzle-kit migrate",
    "db:migrate:prod": "dotenv -e .env.production.local -- drizzle-kit migrate",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && wrangler deploy --config wrangler.toml",
    "cf-deploy": "wrangler deploy --config wrangler.toml",
    "cf-typegen": "wrangler types --config wrangler.toml --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.7",
    "@neondatabase/serverless": "^1.0.2",
    "@opennextjs/cloudflare": "^1.18.0",
    "bufferutil": "^4.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.7.0",
    "next": "^15.5.10",
    "pdf-parse": "^2.4.5",
    "postal-mime": "^2.7.4",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "utf-8-validate": "^6.0.6",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "^15.5.10",
    "postgres": "^3.4.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.78.0"
  }
}
