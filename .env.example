# Copy to .env.local and fill in real values. Never commit secrets.

# Neon (local dev / Drizzle migrate). On Workers, prefer Hyperdrive + binding in wrangler.jsonc.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require

# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# Optional Clerk URLs (defaults work for many setups)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Cloudflare: create Hyperdrive in dashboard, then add to wrangler.jsonc, e.g.:
# "hyperdrive": [{ "binding": "HYPERDRIVE", "id": "<your-hyperdrive-config-id>" }]
# Use env.HYPERDRIVE.connectionString in Worker code when wiring getDb().
