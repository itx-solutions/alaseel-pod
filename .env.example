# Copy to .env.local and fill in real values. Never commit secrets.

# Neon — connection string (local dev, Drizzle CLI, and Workers via Hyperdrive proxy).
# Use the Hyperdrive connection string in production Workers (same shape as Neon URL).
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require

# OpenNext local dev: must match DATABASE_URL when using Hyperdrive in wrangler.toml
# (see https://developers.cloudflare.com/hyperdrive/configuration/local-development/)
CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# Clerk webhook signing secret (Svix) — Webhooks → select endpoint → Signing Secret
CLERK_WEBHOOK_SIGNING_SECRET=whsec_replace_me

# Shopify — Admin API webhook signing secret (Settings → Notifications → Webhooks)
SHOPIFY_WEBHOOK_SECRET=replace_me

# Optional Clerk URLs
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
